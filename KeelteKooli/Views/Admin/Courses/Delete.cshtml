@model KeelteKooli.Models.Course
@{
    ViewBag.Title = "Delete Course";
}

<h2>Kustuta Course</h2>

<p>Kas soovite seda kursust kindlasti kustutada?</p>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Nimetus</dd>
    <dt class="col-sm-2">Language</dt>
    <dd class="col-sm-10">@Model.Keel</dd>
    <dt class="col-sm-2">Level</dt>
    <dd class="col-sm-10">@Model.Tase</dd>
</dl>

@using (Html.BeginForm("DeleteCourse", "Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" href="@Url.Action("Courses", "Admin")">Tühista</a>
}
