@model IEnumerable<KeelteKooli.Models.Teacher>
@{
    ViewBag.Title = "Õpetajad";
}

<h2>Õpetajad</h2>
<p>
    <a class="btn btn-primary" href="@Url.Action("CreateTeacher", "Admin")">Loo uus õpetaja</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Nimi</th>
            <th>Kvalifikatsioon</th>
            <th>Tegevused</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var teacher in Model)
        {
            <tr>
                <td>@teacher.Nimi</td>
                <td>@teacher.Kvalifikatsioon</td>
                <td>
                    <a class="btn btn-sm btn-warning" href="@Url.Action("EditTeacher", "Admin", new { id = teacher.Id })">Muuda</a>
                    <a class="btn btn-sm btn-danger" href="@Url.Action("DeleteTeacher", "Admin", new { id = teacher.Id })">Kustuta</a>
                </td>
            </tr>
        }
    </tbody>
</table>