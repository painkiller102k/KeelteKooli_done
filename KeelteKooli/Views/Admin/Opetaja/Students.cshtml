@model IEnumerable<KeelteKooli.Models.Registration>
@{
    ViewBag.Title = "Õpilased";
}

<h2>Koolituse õpilased</h2>

<p>
    <a class="btn btn-secondary" href="@Url.Action("Dashboard", "Opetaja")">← Tagasi töölauale</a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Sellele koolitusele ei ole veel keegi registreerunud.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>E-post</th>
                <th>Staatus</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.User != null ? item.User.Email : "-")</td>
                    <td>@item.Staatus</td>
                </tr>
            }
        </tbody>
    </table>
}