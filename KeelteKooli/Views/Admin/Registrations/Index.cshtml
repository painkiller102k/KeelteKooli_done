@model IEnumerable<KeelteKooli.Models.Registration>
@{
    ViewBag.Title = "Registreerimised";
}

<h2>Registreerimised</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Õpilane</th>
            <th>Kursus</th>
            <th>Õpetaja</th>
            <th>Algus</th>
            <th>Staatus</th>
            <th>Tegevus</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@(r.User != null ? r.User.Email : "-")</td>
                <td>@(r.Koolitus != null && r.Koolitus.Keelekursus != null ? r.Koolitus.Keelekursus.Nimetus : "-")</td>
                <td>@(r.Koolitus != null && r.Koolitus.Opetaja != null ? r.Koolitus.Opetaja.Nimi : "-")</td>
                <td>@(r.Koolitus != null ? r.Koolitus.AlgusKuupaev.ToString("dd.MM.yyyy") : "-")</td>
                <td>@r.Staatus</td>
                <td class="d-flex gap-2">
                    @using (Html.BeginForm("ConfirmRegistration", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("id", r.Id)
                        <button class="btn btn-sm btn-success" type="submit">Kinnita</button>
                    }

                    @using (Html.BeginForm("CancelRegistration", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("id", r.Id)
                        <button class="btn btn-sm btn-danger" type="submit">Tühista</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>