@model IEnumerable<KeelteKooli.Models.Training>
@using System.Collections.Generic

@{
    ViewBag.Title = "Kõik koolitused";

    var myIds = ViewBag.MyTrainingIds as List<int> ?? new List<int>();
    var counts = ViewBag.Counts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<h2>Kõik koolitused</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Kursus</th>
            <th>Õpetaja</th>
            <th>Algus</th>
            <th>Lõpp</th>
            <th>Hind</th>
            <th>Kohad</th>
            <th>Tegevus</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            var already = myIds.Contains(t.Id);
            var used = counts.ContainsKey(t.Id) ? counts[t.Id] : 0;
            var isFull = used >= t.MaxOsalejaid;

            <tr>
                <td>@(t.Keelekursus != null ? t.Keelekursus.Nimetus : "-")</td>
                <td>@(t.Opetaja != null ? t.Opetaja.Nimi : "-")</td>
                <td>@t.AlgusKuupaev.ToString("dd.MM.yyyy")</td>
                <td>@t.LoppKuupaev.ToString("dd.MM.yyyy")</td>
                <td>@t.Hind</td>
                <td>@used / @t.MaxOsalejaid</td>
                <td>
                    @if (isFull)
                    {
                        <span class="badge text-bg-danger">GRUPP TÄIS</span>
                    }
                    else if (already)
                    {
                        <span class="badge text-bg-success">Registreeritud</span>
                    }
                    else
                    {
                        using (Html.BeginForm("Enroll", "Student", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("id", t.Id)
                            <button type="submit" class="btn btn-sm btn-primary">Registreeru</button>
                        }
                    }
                </td>
            </tr>
        }
    </tbody>
</table>